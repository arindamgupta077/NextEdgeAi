# ================================================================
# NextEdgeAI — Required Environment Variables
# Copy this file to .env.local for local development
# Set these in: Netlify Dashboard → Site Settings → Environment Variables
# ================================================================

# Supabase project URL (find in: Supabase Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (KEEP SECRET — server-side only, never expose publicly)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Public URL of your deployed site (used for redirects)
NEXT_PUBLIC_SITE_URL=https://your-site.netlify.app
